{
  "name": "xdrs-core",
  "version": "0.0.1",
  "description": "A standard way to organize Decision Records (XDRs) across scopes, subjects, and teams so that AI agents can reliably query and follow them.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flaviostutz/xdrs-core.git"
  },
  "keywords": [
    "xdr",
    "adr",
    "decision-records",
    "ai-agents"
  ],
  "license": "MIT",
  "files": [
    ".xdrs/**",
    "package.json",
    "AGENTS.md",
    "bin/npmdata.js"
  ],
  "dependencies": {
    "npmdata": "^0.6.1-beta.0"
  },
  "npmdata": [
    {
      "package": "xdrs-core",
      "outputDir": ".",
      "files": [
        "AGENTS.md",
        ".xdrs/**"
      ]
    }
  ],
  "bin": "bin/npmdata.js"
}
