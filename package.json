{
  "name": "xdrs-core",
  "version": "0.0.1",
  "description": "A standard way to organize Decision Records (XDRs) across scopes, subjects, and teams so that AI agents can reliably query and follow them.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flaviostutz/xdrs-core.git"
  },
  "keywords": [
    "xdr",
    "adr",
    "decision-records",
    "ai-agents"
  ],
  "license": "MIT",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    ".xdrs/_core/**",
    ".xdrs/index.md",
    "package.json",
    "AGENTS.md",
    "bin/filedist.js",
	  "lib/**/*.js"
  ],
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "dependencies": {
    "filedist": "^0.26.0",
    "ignore": "^7.0.5",
    "minimatch": "^10.2.5"
  },
  "filedist": {
    "sets": [
      {
        "selector": {
          "files": [
            "AGENTS.md",
            ".xdrs/_core/**"
          ]
        },
        "output": {
          "path": ".",
          "symlinks": [
            {
              "source": ".xdrs/**/skills/*",
              "target": ".github/skills"
            }
          ],
          "gitignore": false
        }
      },
      {
        "selector": {
          "files": [
            ".xdrs/index.md"
          ]
        },
        "output": {
          "path": ".",
          "gitignore": false,
          "managed": false,
          "keepExisting": true
        }
      }
    ]
  },
  "bin": "bin/filedist.js"
}
