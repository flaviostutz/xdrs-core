{
  "name": "xdrs-core",
  "version": "0.0.1",
  "description": "A standard way to organize Decision Records (XDRs) across scopes, subjects, and teams so that AI agents can reliably query and follow them.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flaviostutz/xdrs-core.git"
  },
  "keywords": [
    "xdr",
    "adr",
    "decision-records",
    "ai-agents"
  ],
  "license": "MIT",
  "files": [
    ".xdrs/**",
    "package.json",
    "AGENTS.md",
    "bin/npmdata.js"
  ],
  "dependencies": {
    "npmdata": "^0.18.13"
  },
  "npmdata": {
    "sets": [
      {
        "selector": {
          "files": [
            "AGENTS.md",
            ".xdrs/**"
          ],
          "exclude": [
            ".xdrs/index.md"
          ]
        },
        "output": {
          "path": ".",
          "symlinks": [
            {
              "source": ".xdrs/**/skills/*",
              "target": ".github/skills"
            }
          ],
          "gitignore": false
        }
      },
      {
        "selector": {
          "files": [
            ".xdrs/index.md"
          ]
        },
        "output": {
          "path": ".",
          "gitignore": false,
          "managed": false,
          "keepExisting": true
        }
      }
    ]
  },
  "bin": "bin/npmdata.js"
}
